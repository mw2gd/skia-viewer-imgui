defines = -DNDEBUG -DSK_TRIVIAL_ABI=\[\[clang$:$:trivial_abi\]\] -DSK_GAMMA_APPLY_TO_A8 -DSK_ALLOW_STATIC_GLOBAL_INITIALIZERS=1 -DGPU_TEST_UTILS=1 -DSK_ENABLE_AVX512_OPTS -DSKIA_IMPLEMENTATION=1 -DSK_TYPEFACE_FACTORY_CORETEXT -DSK_FONTMGR_CORETEXT_AVAILABLE -DSK_GL -DSK_SUPPORT_PDF -DSK_CODEC_DECODES_JPEG -DSK_CODEC_DECODES_JPEG_GAINMAPS -DSK_XML -DSK_ENABLE_ANDROID_UTILS -DSK_HAS_HEIF_LIBRARY -DSK_CODEC_DECODES_ICO -DSK_CODEC_DECODES_PNG -DSK_CODEC_DECODES_RAW -DSK_CODEC_DECODES_WEBP -DSK_HAS_WUFFS_LIBRARY -DSK_CODEC_DECODES_GIF -DSK_CODEC_DECODES_BMP -DSK_CODEC_DECODES_WBMP -DSK_ENABLE_OPTIMIZE_SIZE -DSK_ENABLE_PRECOMPILE -DSK_ASSUME_GL=1 -DSK_GANESH -DSK_USE_PERFETTO -DSK_ENABLE_API_AVAILABLE
framework_dirs =
include_dirs = -I../ext/skia/modules/skresources/include -I../ext/skia
cflags = -Wno-attributes -ffp-contract=off -fstrict-aliasing -fPIC -fvisibility=hidden -isysroot /Applications/Xcode.app/Contents/Developer/Platforms/MacOSX.platform/Developer/SDKs/MacOSX14.5.sdk -target x86_64-apple-macos10.15 -Oz -fno-PIE -fno-pie -g -gdwarf-4
cflags_cc = -std=c++17 -fvisibility-inlines-hidden -fno-exceptions -fno-rtti
root_out_dir = .
target_output_name = libskresources

build obj/modules/skresources/src/libskresources.SkAnimCodecPlayer.o: cxx ../ext/skia/modules/skresources/src/SkAnimCodecPlayer.cpp || obj/minify_sksl.stamp
  source_file_part = SkAnimCodecPlayer.cpp
  source_name_part = SkAnimCodecPlayer
build obj/modules/skresources/src/libskresources.SkResources.o: cxx ../ext/skia/modules/skresources/src/SkResources.cpp || obj/minify_sksl.stamp
  source_file_part = SkResources.cpp
  source_name_part = SkResources

build ./libskresources.a: alink obj/modules/skresources/src/libskresources.SkAnimCodecPlayer.o obj/modules/skresources/src/libskresources.SkResources.o || ./libskia.a obj/experimental/ffmpeg/video_decoder.stamp
  arflags =
  output_extension = .a
  output_dir = 
