defines = -DNDEBUG -DSK_TRIVIAL_ABI=\[\[clang$:$:trivial_abi\]\] -DSK_GAMMA_APPLY_TO_A8 -DSK_ALLOW_STATIC_GLOBAL_INITIALIZERS=1 -DGPU_TEST_UTILS=1 -DSK_ENABLE_AVX512_OPTS -DSK_TYPEFACE_FACTORY_CORETEXT -DSK_FONTMGR_CORETEXT_AVAILABLE -DSK_GL -DSK_SUPPORT_PDF -DSK_CODEC_DECODES_JPEG -DSK_CODEC_DECODES_JPEG_GAINMAPS -DSK_XML -DSK_ENABLE_ANDROID_UTILS -DSK_HAS_HEIF_LIBRARY -DSK_CODEC_DECODES_ICO -DSK_CODEC_DECODES_PNG -DSK_CODEC_DECODES_RAW -DSK_CODEC_DECODES_WEBP -DSK_HAS_WUFFS_LIBRARY -DSK_CODEC_DECODES_GIF -DSK_USE_INTERNAL_VULKAN_HEADERS -DSK_ENABLE_SKOTTIE -DSK_ENABLE_SKOTTIE_SKSLEFFECT -DSK_CODEC_DECODES_BMP -DSK_CODEC_DECODES_WBMP -DSK_ENABLE_OPTIMIZE_SIZE -DSK_ENABLE_PRECOMPILE -DSK_ASSUME_GL=1 -DSK_GANESH -DSK_USE_PERFETTO -DSK_ENABLE_API_AVAILABLE -DSK_SHAPER_PRIMITIVE_AVAILABLE -DSK_SHAPER_CORETEXT_AVAILABLE -DSK_SHAPER_HARFBUZZ_AVAILABLE -DSK_SHAPER_UNICODE_AVAILABLE -DSK_UNICODE_AVAILABLE -DSK_UNICODE_ICU_IMPLEMENTATION
framework_dirs =
include_dirs = -I../ext/skia/include/third_party/vulkan -I../ext/skia/modules/skottie/include -I../ext/skia -I../ext/skia/modules/skshaper/include
cflags = -Wno-attributes -ffp-contract=off -fstrict-aliasing -fPIC -fvisibility=hidden -isysroot /Applications/Xcode.app/Contents/Developer/Platforms/MacOSX.platform/Developer/SDKs/MacOSX14.5.sdk -target x86_64-apple-macos10.15 -Oz -fno-PIE -fno-pie -g -gdwarf-4 -Wall -Wextra -Winit-self -Wpointer-arith -Wsign-compare -Wvla -Wno-deprecated-declarations -Wno-maybe-uninitialized -Wno-psabi -Wno-switch-default -Wno-unused-parameter -fcolor-diagnostics -Weverything -Wno-unknown-warning-option -Wno-weak-template-vtables -Wno-nonportable-include-path -Wno-nonportable-system-include-path -Wno-cast-align -Wno-conversion -Wno-disabled-macro-expansion -Wno-documentation -Wno-documentation-unknown-command -Wno-double-promotion -Wno-exit-time-destructors -Wno-float-equal -Wno-global-constructors -Wno-missing-prototypes -Wno-missing-variable-declarations -Wno-pedantic -Wno-reserved-id-macro -Wno-reserved-identifier -Wno-shift-sign-overflow -Wno-signed-enum-bitfield -Wno-switch-enum -Wno-thread-safety-negative -Wno-undef -Wno-unreachable-code-break -Wno-unreachable-code-return -Wno-unused-macros -Wno-unused-member-function -Wno-non-c-typedef-for-linkage -Wno-cast-function-type-strict -Wno-covered-switch-default -Wno-deprecated -Wno-missing-noreturn -Wno-old-style-cast -Wno-newline-eof -Wno-padded -Wno-return-std-move-in-c++11 -Wno-shadow-field-in-constructor -Wno-shadow-uncaptured-local -Wno-zero-as-null-pointer-constant -Wno-declaration-after-statement -Wno-unsafe-buffer-usage -Wno-range-loop-analysis -Wrange-loop-construct -Wdeprecated-anon-enum-enum-conversion -Wdeprecated-array-compare -Wdeprecated-attributes -Wdeprecated-comma-subscript -Wdeprecated-copy -Wdeprecated-copy-dtor -Wdeprecated-dynamic-exception-spec -Wdeprecated-enum-compare -Wdeprecated-enum-compare-conditional -Wdeprecated-enum-enum-conversion -Wdeprecated-enum-float-conversion -Wdeprecated-increment-bool -Wdeprecated-register -Wdeprecated-this-capture -Wdeprecated-volatile -Wdeprecated-writable-str -Wextra-semi
cflags_cc = -std=c++17 -fvisibility-inlines-hidden -fno-exceptions -fno-rtti -Wnon-virtual-dtor -Wno-noexcept-type -Wno-abstract-vbase-init -Wno-weak-vtables -Wno-c++98-compat -Wno-c++98-compat-pedantic -Wno-undefined-func-template
root_out_dir = .
target_output_name = tests

build obj/modules/skottie/tests.inputdeps.stamp: stamp obj/minify_sksl.stamp obj/third_party/icu/make_data_assembly.stamp
build obj/modules/skottie/src/tests.SkottieTest.o: cxx ../ext/skia/modules/skottie/src/SkottieTest.cpp || obj/modules/skottie/tests.inputdeps.stamp
  source_file_part = SkottieTest.cpp
  source_name_part = SkottieTest
build obj/modules/skottie/tests/tests.AudioLayer.o: cxx ../ext/skia/modules/skottie/tests/AudioLayer.cpp || obj/modules/skottie/tests.inputdeps.stamp
  source_file_part = AudioLayer.cpp
  source_name_part = AudioLayer
build obj/modules/skottie/tests/tests.Expression.o: cxx ../ext/skia/modules/skottie/tests/Expression.cpp || obj/modules/skottie/tests.inputdeps.stamp
  source_file_part = Expression.cpp
  source_name_part = Expression
build obj/modules/skottie/tests/tests.Image.o: cxx ../ext/skia/modules/skottie/tests/Image.cpp || obj/modules/skottie/tests.inputdeps.stamp
  source_file_part = Image.cpp
  source_name_part = Image
build obj/modules/skottie/tests/tests.Keyframe.o: cxx ../ext/skia/modules/skottie/tests/Keyframe.cpp || obj/modules/skottie/tests.inputdeps.stamp
  source_file_part = Keyframe.cpp
  source_name_part = Keyframe
build obj/modules/skottie/tests/tests.PropertyObserver.o: cxx ../ext/skia/modules/skottie/tests/PropertyObserver.cpp || obj/modules/skottie/tests.inputdeps.stamp
  source_file_part = PropertyObserver.cpp
  source_name_part = PropertyObserver
build obj/modules/skottie/tests/tests.Shaper.o: cxx ../ext/skia/modules/skottie/tests/Shaper.cpp || obj/modules/skottie/tests.inputdeps.stamp
  source_file_part = Shaper.cpp
  source_name_part = Shaper
build obj/modules/skottie/tests/tests.Text.o: cxx ../ext/skia/modules/skottie/tests/Text.cpp || obj/modules/skottie/tests.inputdeps.stamp
  source_file_part = Text.cpp
  source_name_part = Text

build obj/modules/skottie/tests.stamp: stamp obj/modules/skottie/src/tests.SkottieTest.o obj/modules/skottie/tests/tests.AudioLayer.o obj/modules/skottie/tests/tests.Expression.o obj/modules/skottie/tests/tests.Image.o obj/modules/skottie/tests/tests.Keyframe.o obj/modules/skottie/tests/tests.PropertyObserver.o obj/modules/skottie/tests/tests.Shaper.o obj/modules/skottie/tests/tests.Text.o || ./libskottie.a ./libskia.a obj/test.stamp ./libskshaper.a obj/modules/skunicode/skunicode.stamp ./libsksg.a ./libskunicode_core.a ./libskunicode_icu.a obj/gpu_tool_utils.stamp obj/load_dynamic_library.stamp obj/flags.stamp obj/tool_utils.stamp
