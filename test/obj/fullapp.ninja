defines = -DNDEBUG -DSK_TRIVIAL_ABI=\[\[clang$:$:trivial_abi\]\] -DSK_GAMMA_APPLY_TO_A8 -DSK_ALLOW_STATIC_GLOBAL_INITIALIZERS=1 -DGPU_TEST_UTILS=1 -DSK_ENABLE_AVX512_OPTS -DSK_USE_INTERNAL_VULKAN_HEADERS -DSK_TYPEFACE_FACTORY_CORETEXT -DSK_FONTMGR_CORETEXT_AVAILABLE -DSK_GL -DSK_SUPPORT_PDF -DSK_CODEC_DECODES_JPEG -DSK_CODEC_DECODES_JPEG_GAINMAPS -DSK_XML -DSK_ENABLE_ANDROID_UTILS -DSK_HAS_HEIF_LIBRARY -DSK_CODEC_DECODES_ICO -DSK_CODEC_DECODES_PNG -DSK_CODEC_DECODES_RAW -DSK_CODEC_DECODES_WEBP -DSK_HAS_WUFFS_LIBRARY -DSK_CODEC_DECODES_GIF -DSK_CODEC_DECODES_BMP -DSK_CODEC_DECODES_WBMP -DSK_ENABLE_OPTIMIZE_SIZE -DSK_ENABLE_PRECOMPILE -DSK_ASSUME_GL=1 -DSK_GANESH -DSK_USE_PERFETTO -DSK_ENABLE_API_AVAILABLE -DIMGUI_ENABLE_OSX_DEFAULT_CLIPBOARD_FUNCTIONS
framework_dirs =
include_dirs = -I../ext/skia/include/third_party/vulkan -I../ext/skia
cflags = -Wno-attributes -ffp-contract=off -fstrict-aliasing -fPIC -fvisibility=hidden -isysroot /Applications/Xcode.app/Contents/Developer/Platforms/MacOSX.platform/Developer/SDKs/MacOSX14.5.sdk -target x86_64-apple-macos10.15 -Oz -fno-PIE -fno-pie -g -gdwarf-4 -Wall -Wextra -Winit-self -Wpointer-arith -Wsign-compare -Wvla -Wno-deprecated-declarations -Wno-maybe-uninitialized -Wno-psabi -Wno-switch-default -Wno-unused-parameter -fcolor-diagnostics -Weverything -Wno-unknown-warning-option -Wno-weak-template-vtables -Wno-nonportable-include-path -Wno-nonportable-system-include-path -Wno-cast-align -Wno-conversion -Wno-disabled-macro-expansion -Wno-documentation -Wno-documentation-unknown-command -Wno-double-promotion -Wno-exit-time-destructors -Wno-float-equal -Wno-global-constructors -Wno-missing-prototypes -Wno-missing-variable-declarations -Wno-pedantic -Wno-reserved-id-macro -Wno-reserved-identifier -Wno-shift-sign-overflow -Wno-signed-enum-bitfield -Wno-switch-enum -Wno-thread-safety-negative -Wno-undef -Wno-unreachable-code-break -Wno-unreachable-code-return -Wno-unused-macros -Wno-unused-member-function -Wno-non-c-typedef-for-linkage -Wno-cast-function-type-strict -Wno-covered-switch-default -Wno-deprecated -Wno-missing-noreturn -Wno-old-style-cast -Wno-newline-eof -Wno-padded -Wno-return-std-move-in-c++11 -Wno-shadow-field-in-constructor -Wno-shadow-uncaptured-local -Wno-zero-as-null-pointer-constant -Wno-declaration-after-statement -Wno-unsafe-buffer-usage -Wno-range-loop-analysis -Wrange-loop-construct -Wdeprecated-anon-enum-enum-conversion -Wdeprecated-array-compare -Wdeprecated-attributes -Wdeprecated-comma-subscript -Wdeprecated-copy -Wdeprecated-copy-dtor -Wdeprecated-dynamic-exception-spec -Wdeprecated-enum-compare -Wdeprecated-enum-compare-conditional -Wdeprecated-enum-enum-conversion -Wdeprecated-enum-float-conversion -Wdeprecated-increment-bool -Wdeprecated-register -Wdeprecated-this-capture -Wdeprecated-volatile -Wdeprecated-writable-str -Wextra-semi -isystem /Users/mattw/repos/fullapp/ext/skia/third_party/externals/imgui
cflags_cc = -std=c++17 -fvisibility-inlines-hidden -fno-exceptions -fno-rtti -Wnon-virtual-dtor -Wno-noexcept-type -Wno-abstract-vbase-init -Wno-weak-vtables -Wno-c++98-compat -Wno-c++98-compat-pedantic -Wno-undefined-func-template
root_out_dir = .
target_output_name = fullapp

build obj/tools/viewer/fullapp.ImGuiLayer.o: cxx ../ext/skia/tools/viewer/ImGuiLayer.cpp || obj/minify_sksl.stamp
  source_file_part = ImGuiLayer.cpp
  source_name_part = ImGuiLayer
build obj/ABS_PATH/Users/mattw/repos/fullapp/src/fullapp.fullapp.o: cxx /Users/mattw/repos/fullapp/src/fullapp.cpp || obj/minify_sksl.stamp
  source_file_part = fullapp.cpp
  source_name_part = fullapp

build ./fullapp: link obj/tools/viewer/fullapp.ImGuiLayer.o obj/ABS_PATH/Users/mattw/repos/fullapp/src/fullapp.fullapp.o obj/tools/sk_app/sk_app.CommandSet.o obj/tools/sk_app/sk_app.Window.o obj/tools/sk_app/mac/sk_app.Window_mac.o obj/tools/sk_app/mac/sk_app.main_mac.o obj/tools/gpu/gpu_tool_utils.BackendSurfaceFactory.o obj/tools/gpu/gpu_tool_utils.BackendTextureImageFactory.o obj/tools/gpu/gpu_tool_utils.ContextType.o obj/tools/gpu/gpu_tool_utils.FlushFinishTracker.o obj/tools/gpu/gpu_tool_utils.GrContextFactory.o obj/tools/gpu/gpu_tool_utils.GrTest.o obj/tools/gpu/gpu_tool_utils.ManagedBackendTexture.o obj/tools/gpu/gpu_tool_utils.MemoryCache.o obj/tools/gpu/gpu_tool_utils.ProtectedUtils.o obj/tools/gpu/gpu_tool_utils.ProxyUtils.o obj/tools/gpu/gpu_tool_utils.TestCanvas.o obj/tools/gpu/gpu_tool_utils.TestContext.o obj/tools/gpu/gpu_tool_utils.TestOps.o obj/tools/gpu/gpu_tool_utils.YUVUtils.o obj/tools/gpu/mock/gpu_tool_utils.MockTestContext.o obj/tools/text/gpu/gpu_tool_utils.TextBlobTools.o obj/tools/gpu/gl/gpu_tool_utils.GLTestContext.o obj/tools/gpu/gl/mac/gpu_tool_utils.CreatePlatformGLTestContext_mac.o obj/tools/gpu/ganesh/gpu_tool_utils.AtlasTextOpTools.o obj/tools/gpu/ganesh/gpu_tool_utils.GrAtlasTools.o obj/tools/library/load_dynamic_library.LoadDynamicLibrary_posix.o obj/tools/tool_utils.AndroidSkDebugToStdOut.o obj/tools/tool_utils.DDLPromiseImageHelper.o obj/tools/tool_utils.DDLTileHelper.o obj/tools/tool_utils.DecodeUtils.o obj/tools/tool_utils.EncodeUtils.o obj/tools/tool_utils.GpuToolUtils.o obj/tools/tool_utils.LsanSuppressions.o obj/tools/tool_utils.MSKPPlayer.o obj/tools/tool_utils.ProcStats.o obj/tools/tool_utils.Resources.o obj/tools/tool_utils.RuntimeBlendUtils.o obj/tools/tool_utils.SkMetaData.o obj/tools/tool_utils.SkSharingProc.o obj/tools/tool_utils.TestFontDataProvider.o obj/tools/tool_utils.ToolUtils.o obj/tools/tool_utils.TsanSuppressions.o obj/tools/tool_utils.UrlDataManager.o obj/tools/debugger/tool_utils.DebugCanvas.o obj/tools/debugger/tool_utils.DebugLayerManager.o obj/tools/debugger/tool_utils.DrawCommand.o obj/tools/debugger/tool_utils.JsonWriteBuffer.o obj/tools/fonts/tool_utils.FontToolUtils.o obj/tools/fonts/tool_utils.RandomScalerContext.o obj/tools/fonts/tool_utils.TestFontMgr.o obj/tools/fonts/tool_utils.TestSVGTypeface.o obj/tools/fonts/tool_utils.TestTypeface.o obj/tools/text/tool_utils.SkTextBlobTrace.o obj/tools/timer/tool_utils.Timer.o obj/tools/tool_utils.CrashHandler.o obj/tools/tool_utils.AutoreleasePool.o obj/tools/flags/flags.CommandLineFlags.o ./libskia.a ./libimgui.a ./libwindow.a || obj/sk_app.stamp obj/gpu_tool_utils.stamp obj/load_dynamic_library.stamp obj/tool_utils.stamp obj/flags.stamp
  ldflags = -Wl,-rpath,@loader_path/. -isysroot /Applications/Xcode.app/Contents/Developer/Platforms/MacOSX.platform/Developer/SDKs/MacOSX14.5.sdk -Wl,-w -target x86_64-apple-macos10.15 -dead_strip
  libs = -ldl
  frameworks = -framework QuartzCore -framework Cocoa -framework Foundation -framework ApplicationServices -framework OpenGL -framework AppKit
  swiftmodules =
