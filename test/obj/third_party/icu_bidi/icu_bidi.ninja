defines = -DU_USING_ICU_NAMESPACE=0 -DU_COMMON_IMPLEMENTATION -DU_STATIC_IMPLEMENTATION -DU_I18N_IMPLEMENTATION -DU_DISABLE_VERSION_SUFFIX=1 -DU_HAVE_LIB_SUFFIX=1 -DU_LIB_SUFFIX_C_NAME=_skia -DNDEBUG -DSK_TRIVIAL_ABI=\[\[clang$:$:trivial_abi\]\] -DSK_USING_THIRD_PARTY_ICU
