defines = -DNDEBUG -DSK_TRIVIAL_ABI=\[\[clang$:$:trivial_abi\]\] -DSK_GAMMA_APPLY_TO_A8 -DSK_ALLOW_STATIC_GLOBAL_INITIALIZERS=1 -DGPU_TEST_UTILS=1 -DSK_ENABLE_AVX512_OPTS -DSK_USE_INTERNAL_VULKAN_HEADERS -DSK_TYPEFACE_FACTORY_CORETEXT -DSK_FONTMGR_CORETEXT_AVAILABLE -DSK_GL -DSK_SUPPORT_PDF -DSK_CODEC_DECODES_JPEG -DSK_CODEC_DECODES_JPEG_GAINMAPS -DSK_XML -DSK_ENABLE_ANDROID_UTILS -DSK_HAS_HEIF_LIBRARY -DSK_CODEC_DECODES_ICO -DSK_CODEC_DECODES_PNG -DSK_CODEC_DECODES_RAW -DSK_CODEC_DECODES_WEBP -DSK_HAS_WUFFS_LIBRARY -DSK_CODEC_DECODES_GIF -DSK_CODEC_DECODES_BMP -DSK_CODEC_DECODES_WBMP -DSK_ENABLE_OPTIMIZE_SIZE -DSK_ENABLE_PRECOMPILE -DSK_ASSUME_GL=1 -DSK_GANESH -DSK_USE_PERFETTO -DSK_ENABLE_API_AVAILABLE
framework_dirs =
include_dirs = -I../ext/skia/include/third_party/vulkan -I../ext/skia
cflags = -Wno-attributes -ffp-contract=off -fstrict-aliasing -fPIC -fvisibility=hidden -isysroot /Applications/Xcode.app/Contents/Developer/Platforms/MacOSX.platform/Developer/SDKs/MacOSX14.5.sdk -target x86_64-apple-macos10.15 -Oz -fno-PIE -fno-pie -g -gdwarf-4
cflags_cc = -std=c++17 -fvisibility-inlines-hidden -fno-exceptions -fno-rtti
root_out_dir = .
target_output_name = skqp_lib

build obj/skqp_lib.inputdeps.stamp: stamp obj/minify_sksl.stamp obj/skia.h.stamp obj/third_party/icu/make_data_assembly.stamp
build obj/tools/skqp/src/skqp_lib.skqp.o: cxx ../ext/skia/tools/skqp/src/skqp.cpp || obj/skqp_lib.inputdeps.stamp
  source_file_part = skqp.cpp
  source_name_part = skqp
build obj/tools/skqp/src/skqp_lib.skqp_GpuTestProcs.o: cxx ../ext/skia/tools/skqp/src/skqp_GpuTestProcs.cpp || obj/skqp_lib.inputdeps.stamp
  source_file_part = skqp_GpuTestProcs.cpp
  source_name_part = skqp_GpuTestProcs

build obj/skqp_lib.stamp: stamp obj/tools/skqp/src/skqp_lib.skqp.o obj/tools/skqp/src/skqp_lib.skqp_GpuTestProcs.o || obj/gm.stamp ./libskia.a obj/tests.stamp obj/tool_utils.stamp obj/gpu_tool_utils.stamp obj/load_dynamic_library.stamp obj/etc1.stamp obj/flags.stamp ./libskottie.a ./libsksg.a ./libskshaper.a ./libskunicode_core.a ./libskunicode_icu.a obj/modules/skottie/gm.stamp obj/modules/skottie/utils.stamp ./libskparagraph.a obj/modules/skparagraph/gm.stamp ./libskresources.a obj/fontmgr_android_tests.stamp obj/fontmgr_fontconfig_tests.stamp obj/fontmgr_mac_ct_tests.stamp obj/test.stamp obj/fontmgr_mac_ct.stamp obj/fontscanner_tests.stamp obj/rust_png_tests.stamp obj/typeface_fontations_tests.stamp obj/modules/bentleyottmann/tests.stamp ./libbentleyottmann.a obj/modules/skottie/tests.stamp obj/modules/skparagraph/tests.stamp obj/modules/sksg/tests.stamp obj/modules/skshaper/tests.stamp obj/modules/skunicode/tests.stamp ./libicu_bidi.a ./libpng.a ./libzlib.a obj/third_party/zlib/zlib_adler32_simd.stamp obj/third_party/zlib/zlib_common_headers.stamp obj/third_party/zlib/zlib_inflate_chunk_simd.stamp obj/third_party/zlib/zlib_slide_hash_simd.stamp obj/third_party/zlib/zlib_crc32_simd.stamp ./libwebp.a ./libwebp_sse41.a
